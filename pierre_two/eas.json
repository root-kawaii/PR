{
  "cli": {
    "version": ">= 16.28.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "simulator": true
      }
    },
    "staging": {
      "autoIncrement": true,
      "distribution": "store",
      "channel": "staging",
      "environment": "preview",
      "env": {
        "APP_ENV": "staging",
        "EXPO_PUBLIC_API_URL": "https://pierreclubs-backend-staging.fly.dev",
        "EXPO_PUBLIC_EAS_PROJECT_ID": "6c405b8b-7cb7-454f-a1a7-fb52014dcf35"
      }
    },
    "preview": {
      "distribution": "internal",
      "channel": "preview",
      "environment": "preview"
    },
    "production": {
      "autoIncrement": true,
      "channel": "production",
      "environment": "production",
      "env": {
        "APP_ENV": "production",
        "EXPO_PUBLIC_API_URL": "https://pierreclubs-backend-prod.fly.dev",
        "EXPO_PUBLIC_EAS_PROJECT_ID": "6c405b8b-7cb7-454f-a1a7-fb52014dcf35"
      }
    }
  },
  "submit": {
    "staging": {
      "ios": {
        "ascAppId": "6761366076"
      }
    },
    "production": {
      "ios": {
        "ascAppId": "6761366768"
      }
    }
  }
}
