# Stripe server key from https://dashboard.stripe.com/apikeys.
# Use a sandbox/test key while developing. Never commit a real key.
STRIPE_SECRET_KEY=sk_test_replace_me

# Optional publishable key for future client-side Stripe.js flows.
STRIPE_PUBLISHABLE_KEY=pk_test_replace_me

# Snapshot webhook signing secret for /webhooks/subscriptions.
# Get this from `stripe listen --forward-to localhost:4242/webhooks/subscriptions`.
STRIPE_WEBHOOK_SECRET=whsec_replace_me

# Thin webhook signing secret for /webhooks/connect-requirements.
# Get this from the Stripe CLI command in README.md.
STRIPE_THIN_WEBHOOK_SECRET=whsec_replace_me

# Platform subscription price. Use an existing recurring Price ID, or click
# "Create sample subscription plan" in the demo UI to create one.
PLATFORM_SUBSCRIPTION_PRICE_ID=price_replace_me

# Demo defaults.
ROOT_URL=http://localhost:4242
PORT=4242
CONNECTED_ACCOUNT_COUNTRY=us
CURRENCY=usd
